{
  "permissions": {
    "allow": [
      "Bash(gh auth *)",
      "Bash(command -v gh)",
      "Read(//opt/homebrew/bin/**)",
      "Bash(command -v git)",
      "Bash(git config *)",
      "Read(//Applications/**)",
      "Bash(brew list *)",
      "Read(//Users/cerstin/.config/**)",
      "Read(//Users/cerstin/**)",
      "Bash(brew --version)",
      "Bash(security find-internet-password *)",
      "WebFetch(domain:websitedemos.net)",
